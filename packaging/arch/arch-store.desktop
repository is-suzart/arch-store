[Desktop Entry]
Name=Arch Store
Comment=Loja de Aplicativos para Arch Linux
Exec=arch-store %U
Icon=system-software-install
Terminal=false
Type=Application
Categories=System;Settings;PackageManager;
MimeType=application/vnd.archlinux.package;application/x-alpm-package;application/vnd.flatpak.ref;application/vnd.flatpak.repo;
